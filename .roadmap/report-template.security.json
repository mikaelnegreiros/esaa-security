{
  "$schema": "report.security.v1",
  "metadata": {
    "title": "ESAA Security Audit Report Template",
    "version": "1.0.0",
    "description": "Template estruturado que define a forma exata do relatório final. O agente SEC-043 projeta os dados dos result files (reports/phase2/results/*.json, reports/phase3/*.json) neste formato. O output é determinístico: mesmos inputs sempre geram o mesmo relatório.",
    "produces": [
      "reports/final/security-audit-report.json",
      "reports/final/security-audit-report.md"
    ],
    "consumes": [
      "reports/phase1/tech-stack-inventory.md",
      "reports/phase1/architecture-map.md",
      "reports/phase1/attack-surface-inventory.md",
      "reports/phase2/results/SEC-*.json",
      "reports/phase3/vulnerability-inventory.json",
      "reports/phase3/classified-vulnerabilities.json",
      "reports/phase3/risk-matrix.json",
      "reports/phase4/technical-remediations.md",
      "reports/phase4/best-practices.md",
      "reports/phase4/executive-summary.md"
    ]
  },

  "report_schema": {

    "header": {
      "report_id": {
        "type": "string",
        "format": "RPT-SEC-{YYYYMMDD}-{RUN_ID}",
        "description": "Identificador único do relatório, derivado da data e run_id.",
        "example": "RPT-SEC-20260304-RUN-SEC-0001"
      },
      "generated_at": {
        "type": "string",
        "format": "date-time",
        "description": "Timestamp UTC de geração do relatório."
      },
      "run_id": {
        "type": "string",
        "description": "run_id do ESAA que produziu este relatório."
      },
      "projection_hash_sha256": {
        "type": "string",
        "description": "Hash da projeção no momento da geração — garante rastreabilidade ao event store."
      },
      "audit_scope": {
        "type": "string",
        "description": "Escopo da auditoria, copiado de project.audit_scope do roadmap."
      },
      "target": {
        "repo_path": { "type": "string" },
        "endpoint_base_url": { "type": ["string", "null"] },
        "tech_stack_summary": { "type": "string", "description": "Resumo do stack (derivado de SEC-001)." }
      }
    },

    "executive_summary": {
      "description": "Visão geral em até 300 palavras. Deve responder: qual o estado geral de segurança, quais são os riscos mais urgentes, e o que precisa ser feito primeiro.",
      "fields": {
        "overall_assessment": {
          "type": "string",
          "description": "Parágrafo descrevendo o estado geral de segurança do sistema."
        },
        "security_score": {
          "type": "object",
          "description": "Score calculado pela fórmula definida em score_calculation.",
          "fields": {
            "value": { "type": "number", "minimum": 0, "maximum": 100 },
            "classification": { "type": "string", "enum": ["critical", "poor", "fair", "good", "excellent"] },
            "breakdown": {
              "type": "object",
              "description": "Score por domínio para identificar áreas mais fracas.",
              "fields": {
                "domain": { "type": "string" },
                "score": { "type": "number", "minimum": 0, "maximum": 100 },
                "checks_pass": { "type": "integer" },
                "checks_fail": { "type": "integer" },
                "checks_na": { "type": "integer" }
              }
            }
          }
        },
        "top_risks": {
          "type": "array",
          "max_items": 5,
          "description": "Os 5 riscos mais críticos, ordenados por severidade × impacto.",
          "item_fields": {
            "rank": { "type": "integer" },
            "check_id": { "type": "string" },
            "vulnerability": { "type": "string" },
            "domain": { "type": "string" },
            "severity": { "type": "string" },
            "impact_summary": { "type": "string" },
            "immediate_action": { "type": "string" }
          }
        },
        "stats": {
          "total_checks_executed": { "type": "integer" },
          "checks_pass": { "type": "integer" },
          "checks_fail": { "type": "integer" },
          "checks_partial": { "type": "integer" },
          "checks_na": { "type": "integer" },
          "domains_audited": { "type": "integer" },
          "critical_findings": { "type": "integer" },
          "high_findings": { "type": "integer" },
          "medium_findings": { "type": "integer" },
          "low_findings": { "type": "integer" },
          "info_findings": { "type": "integer" }
        }
      }
    },

    "vulnerability_matrix": {
      "description": "Tabela completa de todas as vulnerabilidades encontradas, ordenada por severidade decrescente.",
      "columns": [
        "finding_id",
        "check_id",
        "vulnerability",
        "domain",
        "severity",
        "impact_cia",
        "status",
        "remediation_summary"
      ],
      "item_schema": {
        "finding_id": {
          "type": "string",
          "format": "FIND-{NNN}",
          "description": "ID sequencial do achado neste relatório."
        },
        "check_id": {
          "type": "string",
          "description": "Referência ao check do playbook (ex: IV-001, SC-003)."
        },
        "vulnerability": {
          "type": "string",
          "description": "Nome descritivo da vulnerabilidade."
        },
        "domain": {
          "type": "string",
          "description": "Domínio de segurança (ex: input_validation, authentication)."
        },
        "severity": {
          "type": "string",
          "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]
        },
        "impact_cia": {
          "type": "object",
          "description": "Impacto em Confidencialidade, Integridade e Disponibilidade.",
          "fields": {
            "confidentiality": { "type": "string", "enum": ["none", "low", "medium", "high"] },
            "integrity": { "type": "string", "enum": ["none", "low", "medium", "high"] },
            "availability": { "type": "string", "enum": ["none", "low", "medium", "high"] }
          }
        },
        "status": {
          "type": "string",
          "enum": ["fail", "partial"],
          "description": "Apenas findings com fail ou partial entram na matriz."
        },
        "remediation_summary": {
          "type": "string",
          "description": "Resumo da correção em 1-2 frases."
        }
      }
    },

    "detailed_analysis": {
      "description": "Análise técnica organizada por domínio. Cada domínio contém todos os checks executados com resultado, evidência e recomendação.",
      "per_domain": {
        "domain_key": { "type": "string" },
        "domain_title": { "type": "string" },
        "domain_priority": { "type": "string", "enum": ["critical", "high", "medium"] },
        "domain_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "summary": {
          "type": "string",
          "description": "Parágrafo resumindo o estado do domínio."
        },
        "checks": {
          "type": "array",
          "item_schema": {
            "check_id": { "type": "string" },
            "check_name": { "type": "string" },
            "status": { "type": "string", "enum": ["pass", "fail", "partial", "not_applicable", "error"] },
            "severity_if_fail": { "type": "string" },
            "evidence": {
              "type": "object",
              "fields": {
                "files": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Arquivos onde o problema foi encontrado."
                },
                "lines": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Linhas ou trechos relevantes (sem reproduzir código completo)."
                },
                "commands_output": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Output resumido dos comandos executados."
                },
                "description": {
                  "type": "string",
                  "description": "Explicação técnica do achado."
                }
              }
            },
            "remediation": {
              "type": "string",
              "description": "Correção técnica detalhada."
            },
            "references": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Links para OWASP, CWE, NIST ou documentação relevante."
            }
          }
        }
      }
    },

    "priority_risks": {
      "description": "Seção narrativa expandindo os top risks do resumo executivo. Cada risco prioritário recebe análise de impacto, cenário de exploração e roadmap de correção.",
      "item_schema": {
        "rank": { "type": "integer" },
        "finding_id": { "type": "string" },
        "title": { "type": "string" },
        "severity": { "type": "string" },
        "impact_analysis": {
          "type": "string",
          "description": "O que acontece se esta vulnerabilidade for explorada. Cenário concreto."
        },
        "exploitation_scenario": {
          "type": "string",
          "description": "Como um atacante exploraria esta vulnerabilidade. Passo a passo."
        },
        "remediation_roadmap": {
          "type": "object",
          "fields": {
            "immediate": { "type": "string", "description": "O que fazer nas próximas 24h." },
            "short_term": { "type": "string", "description": "O que fazer na próxima sprint (1-2 semanas)." },
            "long_term": { "type": "string", "description": "O que implementar como controle permanente." }
          }
        },
        "effort_estimate": {
          "type": "string",
          "enum": ["hours", "days", "weeks"],
          "description": "Esforço estimado para a correção completa."
        }
      }
    },

    "technical_recommendations": {
      "description": "Recomendações organizadas por prioridade de implementação, não por domínio.",
      "tiers": {
        "tier_1_immediate": {
          "description": "Correções para findings CRITICAL — implementar em até 48h.",
          "items": {
            "finding_id": { "type": "string" },
            "action": { "type": "string" },
            "code_snippet": { "type": ["string", "null"], "description": "Snippet de código ou config se aplicável." },
            "verification_command": { "type": "string", "description": "Comando para verificar que a correção foi aplicada." }
          }
        },
        "tier_2_short_term": {
          "description": "Correções para findings HIGH — implementar em até 2 semanas.",
          "items": {
            "finding_id": { "type": "string" },
            "action": { "type": "string" },
            "code_snippet": { "type": ["string", "null"] },
            "verification_command": { "type": "string" }
          }
        },
        "tier_3_hardening": {
          "description": "Melhorias para findings MEDIUM/LOW — implementar no próximo ciclo.",
          "items": {
            "finding_id": { "type": "string" },
            "action": { "type": "string" }
          }
        },
        "tier_4_best_practices": {
          "description": "Boas práticas gerais e recomendações preventivas.",
          "items": {
            "domain": { "type": "string" },
            "practice": { "type": "string" },
            "reference": { "type": "string" }
          }
        }
      }
    },

    "appendix": {
      "description": "Dados complementares para auditabilidade.",
      "fields": {
        "full_check_results": {
          "description": "Tabela completa de todos os 95 checks com status — inclui pass e not_applicable, não apenas findings.",
          "columns": ["check_id", "domain", "check_name", "status", "severity_if_fail"]
        },
        "audit_metadata": {
          "run_id": { "type": "string" },
          "projection_hash_sha256": { "type": "string" },
          "total_events": { "type": "integer" },
          "audit_start": { "type": "string", "format": "date-time" },
          "audit_end": { "type": "string", "format": "date-time" },
          "agent_model": { "type": "string", "description": "Modelo LLM utilizado." },
          "playbooks_version": { "type": "string" },
          "roadmap_schema_version": { "type": "string", "const": "0.4.0" }
        },
        "domain_coverage": {
          "description": "Mapa de cobertura: quais domínios foram auditados, quais checks foram not_applicable e por quê.",
          "per_domain": {
            "domain": { "type": "string" },
            "total_checks": { "type": "integer" },
            "executed": { "type": "integer" },
            "not_applicable": { "type": "integer" },
            "na_justifications": {
              "type": "array",
              "items": {
                "check_id": { "type": "string" },
                "reason": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },

  "score_calculation": {
    "description": "Fórmula determinística para cálculo do security score. O score é calculado bottom-up: check → domain → global.",

    "check_scoring": {
      "description": "Cada check recebe uma pontuação baseada no status e na severidade.",
      "rules": {
        "pass": {
          "points": "severity_weight",
          "description": "Check aprovado ganha o peso total da severidade."
        },
        "partial": {
          "points": "severity_weight × 0.5",
          "description": "Mitigação parcial ganha metade do peso."
        },
        "fail": {
          "points": 0,
          "description": "Check reprovado não pontua."
        },
        "not_applicable": {
          "points": "excluded",
          "description": "Check não aplicável é removido do denominador."
        },
        "error": {
          "points": 0,
          "description": "Erro na execução do check conta como fail."
        }
      },
      "severity_weights": {
        "CRITICAL": 10,
        "HIGH": 7,
        "MEDIUM": 4,
        "LOW": 2,
        "INFO": 1
      }
    },

    "domain_score": {
      "formula": "domain_score = (sum_of_check_points / max_possible_points) × 100",
      "description": "Score por domínio. max_possible_points exclui checks not_applicable.",
      "example": {
        "domain": "input_validation",
        "checks": [
          { "check_id": "IV-001", "severity": "CRITICAL", "weight": 10, "status": "fail", "points": 0 },
          { "check_id": "IV-002", "severity": "CRITICAL", "weight": 10, "status": "pass", "points": 10 },
          { "check_id": "IV-003", "severity": "HIGH", "weight": 7, "status": "pass", "points": 7 },
          { "check_id": "IV-004", "severity": "HIGH", "weight": 7, "status": "partial", "points": 3.5 },
          { "check_id": "IV-005", "severity": "HIGH", "weight": 7, "status": "pass", "points": 7 },
          { "check_id": "IV-006", "severity": "MEDIUM", "weight": 4, "status": "pass", "points": 4 },
          { "check_id": "IV-007", "severity": "MEDIUM", "weight": 4, "status": "pass", "points": 4 }
        ],
        "sum_points": 35.5,
        "max_possible": 49,
        "domain_score": 72.4
      }
    },

    "global_score": {
      "formula": "global_score = weighted_average(domain_scores, domain_priority_weights)",
      "description": "Média ponderada dos scores de domínio, com peso proporcional à prioridade.",
      "domain_priority_weights": {
        "critical": 3.0,
        "high": 2.0,
        "medium": 1.0
      },
      "example": {
        "calculation": "Σ(domain_score × domain_weight) / Σ(domain_weights)",
        "domains": [
          { "domain": "secrets_config", "priority": "critical", "weight": 3.0, "score": 85.0, "weighted": 255.0 },
          { "domain": "authentication", "priority": "critical", "weight": 3.0, "score": 60.0, "weighted": 180.0 },
          { "domain": "input_validation", "priority": "critical", "weight": 3.0, "score": 72.4, "weighted": 217.2 },
          { "domain": "api_security", "priority": "high", "weight": 2.0, "score": 80.0, "weighted": 160.0 },
          { "domain": "security_headers", "priority": "medium", "weight": 1.0, "score": 90.0, "weighted": 90.0 }
        ],
        "total_weighted": 902.2,
        "total_weights": 12.0,
        "global_score": 75.2,
        "classification": "good"
      }
    },

    "classification_thresholds": {
      "critical":  { "range": "0–30",  "label": "Crítico",    "description": "Vulnerabilidades severas requerem ação imediata." },
      "poor":      { "range": "31–50", "label": "Insuficiente", "description": "Falhas significativas em múltiplos domínios." },
      "fair":      { "range": "51–70", "label": "Regular",    "description": "Controles básicos presentes mas fraquezas notáveis." },
      "good":      { "range": "71–85", "label": "Bom",        "description": "Postura sólida com espaço para hardening." },
      "excellent":  { "range": "86–100","label": "Excelente",  "description": "Controles abrangentes em todos os domínios auditados." }
    },

    "penalty_rules": {
      "description": "Penalidades que reduzem o score global independente da média ponderada.",
      "rules": [
        {
          "condition": "any_check_critical_fail",
          "penalty": "Score global capped em 70 (good) se houver qualquer finding CRITICAL sem mitigação.",
          "formula": "if any check with severity=CRITICAL has status=fail: global_score = min(global_score, 70)"
        },
        {
          "condition": "multiple_critical_fails",
          "penalty": "Score global capped em 50 (poor) se houver 3+ findings CRITICAL.",
          "formula": "if count(CRITICAL fail) >= 3: global_score = min(global_score, 50)"
        },
        {
          "condition": "domain_zero",
          "penalty": "Score global capped em 60 (fair) se qualquer domínio critical tiver score 0.",
          "formula": "if any domain with priority=critical has score=0: global_score = min(global_score, 60)"
        }
      ]
    }
  }
}